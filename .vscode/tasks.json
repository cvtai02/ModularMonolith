{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "generate-openapi-types",
            "command": "npx",
            "type": "process",
            "args": [
                "openapi-typescript",
                "http://localhost:5265/openapi/v1.json",
                "-o",
                "${workspaceFolder}/src/clients/shared/api/lib/types.ts",
                "--properties-required-by-default",
                "true"
            ],
            "problemMatcher": []
        },
        {
            "label": "schedule-openapi-types-after-launch",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$cmd = 'for($i=0; $i -lt 120; $i++){ try { Invoke-WebRequest -Uri ''http://localhost:5265/openapi/v1.json'' -UseBasicParsing -TimeoutSec 2 | Out-Null; openapi-typescript ''http://localhost:5265/openapi/v1.json'' -o ''${workspaceFolder}/src/clients/shared/api/lib/openapi-types.ts''; exit $LASTEXITCODE } catch { Start-Sleep -Seconds 1 } } Write-Error ''OpenAPI endpoint not ready in 120s.''; exit 1'; Start-Process -WindowStyle Hidden -FilePath 'powershell' -ArgumentList @('-NoProfile','-ExecutionPolicy','Bypass','-Command',$cmd) | Out-Null"
            ],
            "problemMatcher": []
        },
        {
            "label": "build-and-schedule-openapi-types",
            "dependsOrder": "sequence",
            "dependsOn": [
                "build",
                "schedule-openapi-types-after-launch"
            ],
            "problemMatcher": []
        }
    ]
}
